# Ignore IDE-specific files
.idea/
.vscode/

# Ignore Python cache and build artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
*.py,cover
.python-version
build/
dist/
*.egg-info/
*.swp
*.swo

# Ignore database-related files
*.sqlite3
*.db
*.log

# Ignore virtual environment files
venv/
env/
.venv/
env.bak/

# Ignore migration files
alembic/versions/*.pyc

# Ignore test output and coverage reports
.coverage
.coverage.*
htmlcov/
reports/
.pytest_cache/

# Ignore temporary files and backups
*~
*.bak
*.tmp

# Ignore environment-specific files
.env
backend/.env

# Ignore type checker and linter caches
.mypy_cache/
.ruff_cache/
.pyre/