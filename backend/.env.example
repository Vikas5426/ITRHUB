ENVIRONMENT=development
DATABASE_URL=sqlite+aiosqlite:///./itrhub.db
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Generate long, independent values for both secrets in production.
SECRET_KEY=replace-with-a-long-random-session-secret
DOCUMENT_ENCRYPTION_KEY=replace-with-a-separate-long-random-document-secret
SECURE_COOKIES=false
AUTO_CREATE_TABLES=true
MAX_DOCUMENT_BYTES=10485760
